{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "targetPath",
    "title",
    "frontMatter",
    "markdown",
    "sourceFiles",
    "warnings"
  ],
  "properties": {
    "targetPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(documentation/)?docs/.+\\.mdx?$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "frontMatter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sidebar_position", "title"],
      "properties": {
        "sidebar_position": {
          "type": "number"
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "markdown": {
      "type": "string",
      "minLength": 1
    },
    "sourceFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
